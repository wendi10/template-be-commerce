# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=ecommerce-api
APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
APP_DEBUG=true
LOG_LEVEL=info

# ─── MySQL Database ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=ecommerce
DB_PASSWORD=ecommerce123
DB_ROOT_PASSWORD=rootpassword
DB_NAME=ecommerce
DB_CHARSET=utf8mb4
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_MAX_LIFETIME=5m

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-this-to-a-secure-random-string-64-chars
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string-64-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ─── Payment Gateway – Doku ───────────────────────────────────────────────────
DOKU_CLIENT_ID=your-doku-client-id
DOKU_SECRET_KEY=your-doku-secret-key
DOKU_BASE_URL=https://api-sandbox.doku.com
PAYMENT_CALLBACK_URL=https://yourdomain.com/api/v1/payments/callback
